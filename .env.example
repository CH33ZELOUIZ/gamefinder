# Copy to .env and fill in your own values. Do not commit real secrets.
TZ=UTC
SECRET_KEY=replace-with-a-long-random-string

# Optional basic auth for the web UI. Leave blank to disable auth on trusted LAN only.
GAMEFINDER_USER=
GAMEFINDER_PASSWORD=

# Prowlarr
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=replace-with-your-prowlarr-api-key
# Comma-separated Prowlarr indexer IDs that are fast and game/console-capable.
GAMEFINDER_INDEXER_IDS=
PROWLARR_CONSOLE_CATEGORIES=1000
PROWLARR_SEARCH_TIMEOUT=15

# qBittorrent
QBIT_URL=http://qbittorrent:8080
QBIT_CATEGORY=roms
QBIT_SAVE_PATH=/downloads/roms/_incoming
# If qBittorrent reports paths from its own container instead of this app's /roms mount,
# set the qBittorrent-side root here. Example: /downloads/roms
QBIT_CONTAINER_ROOT=

# RomM integration; DB fields are optional and only power landing-page widgets.
ROMM_URL=http://romm:8080
DB_HOST=
DB_NAME=romm
DB_USER=
DB_PASSWD=

# Host bind mounts used by docker-compose.yml
ROMS_HOST_PATH=./roms
ROMM_RESOURCES_HOST_PATH=./romm_resources
